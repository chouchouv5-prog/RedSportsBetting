    <item>
      <title>My Bets</title>
      <link>https://redsportsbetting.pages.dev/my-bets/</link>
      <pubDate>Wed, 01 Jul 2026 00:00:00 +0000</pubDate>
      <guid>https://redsportsbetting.pages.dev/my-bets/</guid>
      <description>&lt;div id=&#34;bets-container&#34;&gt;Loading your bets...&lt;/div&gt;&#xA;&lt;script&gt;&#xA;async function loadMyBets() {&#xA;    const { data: { user } } = await supabaseClient.auth.getUser();&#xA;    const container = document.getElementById(&#39;bets-container&#39;);&#xA;&#xA;    if (!user) {&#xA;        container.innerHTML = `&lt;p&gt;Please &lt;a href=&#34;https://redsportsbetting.pages.dev/&#34;&gt;login&lt;/a&gt; to see your bets.&lt;/p&gt;`;&#xA;        return;&#xA;    }&#xA;&#xA;    const { data: bets, error } = await supabaseClient&#xA;        .from(&#39;bets&#39;)&#xA;        .select(&#39;*, matches(team_home, team_away, match_date)&#39;)&#xA;        .eq(&#39;user_id&#39;, user.id)&#xA;        .order(&#39;created_at&#39;, { ascending: false });&#xA;&#xA;    if (!bets || bets.length === 0) {&#xA;        container.innerHTML = &#34;&lt;p&gt;You haven&#39;t placed any bets yet. &lt;a href=&#39;https://redsportsbetting.pages.dev/matches/&#39;&gt;See upcoming matches&lt;/a&gt;.&lt;/p&gt;</description>
    </item>
    <item>
      <title>My Profile</title>
      <link>https://redsportsbetting.pages.dev/profile/</link>
      <pubDate>Mon, 29 Jun 2026 00:00:00 +0000</pubDate>
      <guid>https://redsportsbetting.pages.dev/profile/</guid>
      <description>&lt;h1 id=&#34;my-profile&#34;&gt;My Profile&lt;/h1&gt;&#xA;&lt;div id=&#34;profile-content&#34;&gt;&#xA;    Loading your profile...&#xA;&lt;/div&gt;&#xA;&lt;script&gt;&#xA;async function loadProfile() {&#xA;    const { data: { user } } = await supabaseClient.auth.getUser();&#xA;    if (!user) {&#xA;        document.getElementById(&#39;profile-content&#39;).innerHTML = `&lt;p&gt;Please &lt;a href=&#34;https://redsportsbetting.pages.dev/&#34;&gt;login&lt;/a&gt; first.&lt;/p&gt;`;&#xA;        return;&#xA;    }&#xA;&#xA;    const { data: profile } = await supabaseClient&#xA;        .from(&#39;profiles&#39;)&#xA;        .select(&#39;vsb_coins&#39;)&#xA;        .eq(&#39;user_id&#39;, user.id)&#xA;        .single();&#xA;&#xA;    document.getElementById(&#39;profile-content&#39;).innerHTML = `&#xA;        &lt;p&gt;&lt;strong&gt;Email:&lt;/strong&gt; ${user.email}&lt;/p&gt;&#xA;        &lt;p&gt;&lt;strong&gt;VSB Coins:&lt;/strong&gt; &lt;span style=&#34;color: gold; font-size: 1.8em;&#34;&gt;${profile ? profile.vsb_coins : 1000}&lt;/span&gt;&lt;/p&gt;&#xA;        &lt;button onclick=&#34;logout()&#34; style=&#34;padding: 12px 24px; background: #ff4444; color: white; border: none; border-radius: 5px; cursor: pointer;&#34;&gt;Logout&lt;/button&gt;&#xA;    `;&#xA;}&#xA;&#xA;function logout() {&#xA;    supabaseClient.auth.signOut().then(() =&gt; location.href = &#34;/&#34;);&#xA;}&#xA;&#xA;loadProfile();&#xA;&lt;/script&gt;</description>
    </item>
